{
  "info": {
    "name": "Anime Project API",
    "description": "API Documentation untuk Final Project Anime",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Anime (Master & 3rd Party)",
      "item": [
        {
          "name": "Search Jikan API (3rd Party)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/anime/jikan/search?q=naruto",
              "host": ["{{base_url}}"],
              "path": ["api", "anime", "jikan", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "naruto"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Anime",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/anime",
              "host": ["{{base_url}}"],
              "path": ["api", "anime"]
            }
          }
        },
        {
          "name": "Create Anime (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "One Piece",
                  "type": "text"
                },
                {
                  "key": "synopsis",
                  "value": "Mencari harta karun legendaris.",
                  "type": "text"
                },
                {
                  "key": "episodes",
                  "value": "1100",
                  "type": "text"
                },
                {
                  "key": "isPremium",
                  "value": "true",
                  "type": "text"
                },
                {
                  "key": "coverImage",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/anime",
              "host": ["{{base_url}}"],
              "path": ["api", "anime"]
            }
          }
        },
        {
          "name": "Update Anime (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "episodes",
                  "value": "1101",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/anime/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "anime", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "ISI_DENGAN_ID_ANIME"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Anime (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/anime/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "anime", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "ISI_DENGAN_ID_ANIME"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Transactions",
      "item": [
        {
          "name": "Purchase Premium Anime",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"paymentMethod\": \"e-wallet\",\n    \"items\": [\n        {\n            \"animeId\": \"ISI_DENGAN_ID_ANIME_1\",\n            \"price\": 50000\n        },\n        {\n            \"animeId\": \"ISI_DENGAN_ID_ANIME_2\",\n            \"price\": 30000\n        }\n    ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/transactions/purchase",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "purchase"]
            }
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/transactions/history",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "history"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
